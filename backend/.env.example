# ThreatVision Sniffer Agent Configuration

# Remote Backend URL (e.g., https://your-threatvision-backend.onrender.com/analyze)
TV_API_URL=http://localhost:8000/analyze

# Sniffer credential sent in the Authorization header.
# For local testing against the deployed backend, this should match the backend
# service environment variable `TV_AGENT_API_KEY` (preferred) or `TV_API_KEY`.
TV_API_KEY=your_sniffer_agent_key_here

# Optional backend-side machine token for the local sniffer agent.
# Set this on the backend service (for example in Render) so the API can accept
# the sniffer without requiring a Supabase user JWT.
TV_AGENT_API_KEY=your_sniffer_agent_key_here

# Network Interface to Sniff on (Optional, e.g., eth0, wlan0)
# Leave empty to sniff on all interfaces
# TV_INTERFACE=
