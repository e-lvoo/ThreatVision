# ThreatVision Sniffer Agent Configuration

# Remote Backend URL (e.g., https://your-threatvision-backend.onrender.com/analyze)
TV_API_URL=http://localhost:8000/analyze

# Bearer Token for Authentication (Obtained from Supabase or Backend Admin)
TV_API_KEY=your_bearer_token_here

# Network Interface to Sniff on (Optional, e.g., eth0, wlan0)
# Leave empty to sniff on all interfaces
# TV_INTERFACE=
